# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env

# Токен бота — получить у @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# ID администраторов через запятую (для /admin, /broadcast, /stats)
# Свой ID можно узнать у @userinfobot
ADMIN_IDS=123456789

# Путь к базе данных (опционально, по умолчанию selenyx.db рядом с bot.py)
# На Railway база живёт в /data/selenyx.db (Railway Volume)
# DB_PATH=/data/selenyx.db

# Режим демо — отключает HMAC-аутентификацию для тестирования в браузере
# НИКОГДА не ставить true в production!
# DEMO_MODE=false

# URL нового Mini App (GitHub Pages) — используется в MenuButton бота
# По умолчанию уже вшит в код: https://anastasiatrusova204-beep.github.io/selenyx/
# TG_APP_URL=https://anastasiatrusova204-beep.github.io/selenyx/

# Порт API (по умолчанию 8080, nginx проксирует снаружи)
PORT=8080

# На Beget VPS — раскомментировать:
# DB_PATH=/data/selenyx.db

# ЮKassa — подключить перед монетизацией (Шаг 12)
# YOOKASSA_SHOP_ID=your_shop_id
# YOOKASSA_SECRET_KEY=your_secret_key

# OpenAI — подключить для AI-инсайтов в онбординге
# OPENAI_API_KEY=sk-...

# Railway устанавливает автоматически (не нужно на Beget):
# RAILWAY_PUBLIC_DOMAIN=selenyx-bot-production.up.railway.app
