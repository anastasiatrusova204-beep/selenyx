# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env

# Токен бота — получить у @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# ID администраторов через запятую (для /admin и /broadcast)
# Свой ID можно узнать у @userinfobot
ADMIN_IDS=123456789

# Путь к базе данных (опционально, по умолчанию selenyx.db рядом с bot.py)
# DB_PATH=selenyx.db

# URL Mini App — на Railway подставляется автоматически из RAILWAY_PUBLIC_DOMAIN
# Если Railway не добавил домен, укажи вручную:
# WEBAPP_URL=https://your-service.up.railway.app/webapp
