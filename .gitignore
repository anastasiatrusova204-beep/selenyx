# Секреты — никогда не заливать в GitHub
.env

# Виртуальное окружение — у каждого своё, не нужно хранить
venv/

# Системный мусор macOS
.DS_Store

# Кэш Python
__pycache__/
*.pyc
*.pyo

# Логи и рантайм-файлы
bot.log
bot.pid

# База данных (локальная, не хранить в репозитории)
*.db
cache/

# Сгенерированные файлы (кроме webapp и landing)
*.html
!webapp/*.html
!landing/*.html

# SQLite WAL-файлы
*.db-shm
*.db-wal
